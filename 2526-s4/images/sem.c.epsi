/pagesave save def
iso1dict begin
gsave
llx lly 12 add translate
/v 0 store
/x0 x v get 4.850123 add sx cw mul add store
/y0 y v get bfs th add sub store
x0 y0 moveto
(    ) p n
(    #include <semaphore.h>) N
(    ) N
(    ) S
(int) k
( variable1;) p n
(    sem_t lock1;) N
(    ) N
(    ) S
(void) k
( *) p n
(    thread1 \() S
(void) k
( *thread1args\)) p n
(    {) N
(        ) S
(/*... */) c n
(        sem_lock \(&lock1\);) p n
(        ) S
(/*... do critical stuff on variable 1 ... */) c n
(        sem_post \(&lock1\);) p n
(        ) S
(/*... */) c n
(    }) p n
(    ) N
(    main \(\)) N
(    {) N
(        msem_init \(&lock1, MSEM_UNLOCKED\);) N
(        ) S
(/*... */) c n
(    }) p n
(sem.c) () (CODE LISTING) title
grestore
() () () footer
end % of iso1dict
pagesave restore
showpage

end
%%Trailer
cleartomark countdictstack exch sub { end } repeat restore
