/pagesave save def
iso1dict begin
gsave
llx lly 12 add translate
/v 0 store
/x0 x v get 4.850123 add sx cw mul add store
/y0 y v get bfs th add sub store
x0 y0 moveto
(    ) p n
(    processlD turn;) N
(    ) S
(int) k
( Interested[MAXID];) p n
(    ) N
(    EnterCS \(processID proc\)) N
(    {) N
(        processID other;) N
(        other = OtherID \(proc\);) N
(        Interested[proc] = TRUE;) N
(        turn = proc;) N
(        ) S
(while) K
( \(\(turn == proc\) && Interested[other]\);        ) p
(/* wait */) c n
(    }) p n
(    ) N
(    LeaveCS \(processID proc\)) N
(    {) N
(        Interested[proc] = FALSE;) N
(    }) N
(peterson.c) () (CODE LISTING) title
grestore
() () () footer
end % of iso1dict
pagesave restore
showpage

end
