(int) k
( argc, ) p
(char) k
( *argv[]\)) p n
(    {) N
(        ) S
(int) k
( len, how;) p n
(        ) S
(if) K
( \(argc != 3\) {) p n
(            printf \(") S
(usage: send queue_id msg_text\\n) str
("\);) p n
(            exit \(1\);) N
(        }) N
(        msg.mtype = 0;) N
(        ) S
(for) K
( \(len = 0; \(len < 255\) && argv[2][len]; len++\)) p n
(            msg.mtext[len] = argv[2][len];) N
(        msg.mtext[len] = 0;) N
(        printf \(") S
(Message text is %s\\n) str
(", &msg.mtext[0]\);) p n
(        how = msgsnd \(atoi \(argv[1]\), &msg.mtext[0], len + 1, IPC_NOWAIT\);) N
(        ) S
(if) K
( \(how == -1\) {) p n
(            perror \(") S
(cannot send) str
("\);) p n
(            exit \(2\);) N
(        }) N
(    }) N
(send.c) () (CODE LISTING) title
grestore
() () () footer
end % of iso1dict
